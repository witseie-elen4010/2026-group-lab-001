<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles/main.css">
  <script src="/scripts/lecturer_search.js" defer></script>
</head>
<body class="page page_home">
  <main class="card card_even_wider text_center">
    <header>
      <h1><%= homeTitle %></h1>
      <% if (username) { %>
        <p>Hello <%= username %></p>
      <% } %>
      <% if (role) { %>
        <p>You are logged in as a <%= role %>.</p>
      <% } %>
    </header>

    <% if (role === 'student' && username) { %>
      <section class="home_navigation">
        <h2 class="home_navigation_title">Navigation</h2>
        <p class="home_navigation_text">Choose an option below.</p>
        <a href="/user_profile?user=<%= encodeURIComponent(username) %>">User Profile</a>
        <a href="/schedule_consultation">Schedule a Consultation</a>
      </section>
    <% } else if (role === 'lecturer' && username) { %>
      <section class="home_navigation">
        <h2 class="home_navigation_title">Navigation</h2>
        <p class="home_navigation_text">Choose an option below.</p>
        <a href="/user_profile?user=<%= encodeURIComponent(username) %>">User Profile</a>
        <a href="/scheduled_consultations">Scheduled Consultations</a>
      </section>
    <% } else if (username) { %>
      <a class="back_link" href="/user_profile?user=<%= encodeURIComponent(username) %>">User Profile</a>
    <% } %>

    <section class="calendar_section">
      <h2 class="calendar_title"><%= calendar.monthLabel %></h2>
      <table class="calendar_table">
        <thead>
          <tr>
            <% calendar.dayLabels.forEach((dayLabel) => { %>
              <th class="calendar_heading" scope="col"><%= dayLabel %></th>
            <% }) %>
          </tr>
        </thead>
        <tbody>
          <% calendar.weeks.forEach(function (week) { %>
            <tr>
              <% week.forEach(function (day) { %>
                <% if (!day.isEmpty) { %>
                  <td class="calendar_day<%= day.availabilityState === 'available' ? ' calendar_day_available' : '' %><%= day.availabilityState === 'unavailable' ? ' calendar_day_unavailable' : '' %>">
                    <div class="calendar_day_content">
                      <span class="calendar_day_number"><%= day.dayNumber %></span>
                      <% if (day.availabilityText) { %>
                        <span class="calendar_day_note"><%= day.availabilityText %></span>
                      <% } %>
                    </div>
                  </td>
                <% } else { %>
                  <td class="calendar_day calendar_day_empty"></td>
                <% } %>
              <% }) %>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </section>

    <% if (role === 'student') { %>
      <h1>Find a Lecturer</h1>
      <section>
        <form id="lecturer_search_form" action="/home" method="get">
          <div class="search_criteria">
            <label class="search_filter">
              Faculty
              <select name="facultyId">
                <option value="">All faculties</option>
                <% faculties.forEach(function (faculty) { %>
                  <option value="<%= faculty %>" <%= facultyId === faculty ? 'selected' : '' %>>
                    <%= faculty %>
                  </option>
                <% }) %>
              </select>
            </label>

            <label class="search_filter">
              School
              <select name="schoolId">
                <option value="">All schools</option>
                <% schools.forEach(function (school) { %>
                  <option value="<%= school %>" <%= schoolId === school ? 'selected' : '' %>>
                    <%= school %>
                  </option>
                <% }) %>
              </select>
            </label>
          </div>

          <div class="search_flex">
            <label class="search_box">
              Search
              <input type="text" name="q" value="<%= query %>" placeholder="Name and/or username">
            </label>

            <button type="submit" class="search_button">Search</button>
          </div>
        </form>
      </section>

      <section id="lecturer_results" class="results">
        <% if (lecturers.length === 0) { %>
          <p>No lecturers found.</p>
        <% } else { %>
          <% lecturers.forEach(function (lecturer) { %>
            <a href="/user_profile?user=<%= encodeURIComponent(lecturer.username) %>">
              <%= lecturer.firstName %> <%= lecturer.lastName %> &mdash; <%= lecturer.facultyId %>, <%= lecturer.schoolId %>
            </a>
          <% }) %>

          <% if (totalPages > 1) { %>
            <nav class="pagination">
              <% for (let i = 1; i <= totalPages; i++) { %>
                <a
                  href="/home?q=<%= encodeURIComponent(query) %>&facultyId=<%= encodeURIComponent(facultyId) %>&schoolId=<%= encodeURIComponent(schoolId) %>&page=<%= i %>"
                  class="pagination_link<%= i === page ? ' pagination_link_active' : '' %>"
                ><%= i %></a>
              <% } %>
            </nav>
          <% } %>
        <% } %>
      </section>
    <% } %>
  </main>
</body>
</html>
