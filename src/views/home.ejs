<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles/main.css">
</head>
<body class="page page_home">
  <main class="card card_wide text_center">
    <header>
      <h1><%= homeTitle %></h1>
      <% if (username) { %>
        <p>Hello <%= username %></p>
      <% } %>
      <% if (role) { %>
        <p>You are logged in as a <%= role %>.</p>
      <% } %>
    </header>
    <% if (username) { %>
      <a class="back_link" href="/user_profile?user=<%= encodeURIComponent(username) %>&viewer=<%= encodeURIComponent(username) %>">User Profile</a>
    <% } %>
  </main>
</body>
</html>