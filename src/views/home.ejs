<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/styles/main.css">
</head>
<body class="page page_home">
  <main class="card card_even_wider text_center">
    <header>
      <h1><%= homeTitle %></h1>
      <% if (username) { %>
        <p>Hello <%= username %></p>
      <% } %>
      <% if (role) { %>
        <p>You are logged in as a <%= role %>.</p>
      <% } %>
    </header>

    <% if (role === 'student' && username) { %>
      <section class="home_navigation">
        <h2 class="home_navigation_title">Navigation</h2>
        <p class="home_navigation_text">Choose an option below.</p>
        <a href="/user_profile?user=<%= encodeURIComponent(username) %>">User Profile</a>
        <a href="/schedule_consultation">Schedule a Consultation</a>
      </section>
    <% } else if (role === 'lecturer' && username) { %>
      <section class="home_navigation">
        <h2 class="home_navigation_title">Navigation</h2>
        <p class="home_navigation_text">Choose an option below.</p>
        <a href="/user_profile?user=<%= encodeURIComponent(username) %>">User Profile</a>
        <a href="/scheduled_consultations">Scheduled Consultations</a>
      </section>
    <% } else if (username) { %>
      <a class="back_link" href="/user_profile?user=<%= encodeURIComponent(username) %>">User Profile</a>
    <% } %>

    <% if (role === 'student') { %>
      <section>
        <form action="/home" method="get">
          <label>
            Search
            <input type="text" name="q" value="<%= query %>" placeholder="Name or username">
          </label>

          <label>
            Faculty
            <select name="facultyId">
              <option value="">All faculties</option>
              <% faculties.forEach(function (faculty) { %>
                <option value="<%= faculty %>" <%= facultyId === faculty ? 'selected' : '' %>>
                  <%= faculty %>
                </option>
              <% }) %>
            </select>
          </label>

          <label>
            School
            <select name="schoolId">
              <option value="">All schools</option>
              <% schools.forEach(function (school) { %>
                <option value="<%= school %>" <%= schoolId === school ? 'selected' : '' %>>
                  <%= school %>
                </option>
              <% }) %>
            </select>
          </label>

          <button type="submit">Search</button>
        </form>
      </section>

      <section class="results">
        <% if (lecturers.length === 0) { %>
          <p>No lecturers found.</p>
        <% } else { %>
          <% lecturers.forEach(function (lecturer) { %>
            <a href="/lecturer/<%= lecturer.username %>">
              <%= lecturer.firstName %> <%= lecturer.lastName %> &mdash; <%= lecturer.facultyId %>, <%= lecturer.schoolId %>
            </a>
          <% }) %>
        <% } %>
      </section>
    <% } %>

    <section class="calendar_section">
      <h2 class="calendar_title"><%= calendar.monthLabel %></h2>
      <table class="calendar_table">
        <thead>
          <tr>
            <% calendar.dayLabels.forEach((dayLabel) => { %>
              <th class="calendar_heading" scope="col"><%= dayLabel %></th>
            <% }) %>
          </tr>
        </thead>
        <tbody>
          <% calendar.weeks.forEach((week) => { %>
            <tr>
              <% week.forEach((dayNumber) => { %>
                <% if (dayNumber) { %>
                  <td class="calendar_day"><%= dayNumber %></td>
                <% } else { %>
                  <td class="calendar_day calendar_day_empty"></td>
                <% } %>
              <% }) %>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </section>
  </main>
</body>
</html>
